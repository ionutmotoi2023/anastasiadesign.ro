# SMTP Configuration — setează în Railway Dashboard → Variables
# Exemplu pentru email pe domeniul propriu (cPanel/hosting):
#   SMTP_HOST=mail.anastasiadesign.ro
#   SMTP_PORT=587
#   SMTP_USER=office@anastasiadesign.ro
#   SMTP_PASS=parola-emailului
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=office@anastasiadesign.ro
CONTACT_EMAIL=office@anastasiadesign.ro

# Railway sets PORT automatically
PORT=3000
